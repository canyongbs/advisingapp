#!/command/with-contenv bash

max_attempts=3
attempt=1

# Use HTTPS directly when SSL is enabled to avoid 301 redirects in full mode
if [[ "$SSL_MODE" == "full" || "$SSL_MODE" == "mixed" ]]; then
	check_url="https://localhost:8443/ping"
else
	check_url="http://localhost:8080/ping"
fi

while [ $attempt -le $max_attempts ]; do
	response=$(curl -s -o /dev/null -w "%{http_code}" --insecure "$check_url")
	
	if [[ $response == "200" ]]; then
        echo "✅ Web server is responding correctly."
		exit 0
	fi
	
	if [ $attempt -lt $max_attempts ]; then
        echo "⚠️ Web server not responding correctly (HTTP $response). Retrying... ($attempt/$max_attempts)"
		sleep 1
	fi
	((attempt++))
done

echo "❌ There seems to be a failure in checking the web server after $max_attempts attempts."
exit 1